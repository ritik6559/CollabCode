# Server
PORT=8000
CLIENT_URL=http://localhost:3000

# Auth
JWT_SECRET=change-me-to-a-long-random-string

# PostgreSQL (Prisma)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/collabcode

# S3 content storage (room text + Yjs state live here, not in Postgres)
S3_BUCKET=collabcode-content
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
# Optional: point at MinIO/LocalStack for local dev
# S3_ENDPOINT=http://localhost:9000
